rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'klypsocialofficial@gmail.com';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && (
        request.auth.uid == resource.data.get('authorId', '') || 
        request.auth.uid == resource.data.get('ownerId', '')
      );
    }
    
    function isValidPost(data) {
      return data.get('content', '') is string &&
             data.get('privacy', 'public') in ['public', 'private', 'followers', 'circle'];
    }

    function isFollowing(userId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.get('followers', []);
    }

    match /users {
      allow list: if isAuthenticated();
      match /{userId} {
        allow read: if true;
        allow create: if isOwner(userId);
        allow update: if isAdmin() || 
                      (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVerified', 'premiumTier', 'isPremium']));
        allow delete: if isAdmin();
      }
    }

    match /followRequests {
      allow list: if isAuthenticated();
      
      match /{requestId} {
        allow read: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() && (resource.data.receiverId == request.auth.uid || resource.data.senderId == request.auth.uid);
        allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      }
    }

    match /posts {
      allow list: if true;
      
      match /{postId} {
        allow read: if isAdmin() ||
                     resource.data.get('privacy', 'public') == 'public' ||
                     isAuthenticated() && (
                       resource.data.get('authorId', '') == request.auth.uid ||
                       request.auth.uid in resource.data.get('audience', []) ||
                       resource.data.get('ownerId', '') == request.auth.uid
                     );
        
        allow create: if (isAuthenticated() || (request.resource.data.get('authorId', '') == 'anonymous')) && isValidPost(request.resource.data);
        
        allow update: if isAdmin() ||
                      (isDocOwner() && (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['authorName', 'authorPhoto']) ||
                        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['likes', 'likesCount', 'repliesCount', 'reposts', 'repostsCount', 'viewCount']) && isValidPost(request.resource.data))
                      )) ||
                      (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likesCount', 'repliesCount', 'reposts', 'repostsCount', 'viewCount']));
        
        allow delete: if isDocOwner() || isAdmin();
      }
    }

    match /communities {
      allow list: if true;
      match /{communityId} {
        allow read: if true;
        allow create, delete: if isAdmin();
        allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'membersCount']));
      }
    }

    match /missions {
      allow list: if isAuthenticated();
      
      match /{missionId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    match /lists {
      allow list: if isAuthenticated();
      match /{listId} {
        allow read, write: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      }
    }
    
    match /notifications {
      allow list: if isAuthenticated();
      
      match /{notificationId} {
        allow read: if isAuthenticated() && resource.data.get('recipientId', '') == request.auth.uid;
        allow update, delete: if isAdmin() || (isAuthenticated() && (
          resource.data.get('recipientId', '') == request.auth.uid ||
          resource.data.get('senderId', '') == request.auth.uid
        ));
        allow create: if isAuthenticated();
      }
    }
    
    match /conversations {
      allow list: if isAuthenticated();
      
      match /{conversationId} {
        allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
        allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
        allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
        
        match /{allSegments=**} {
          allow read, write: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || isAdmin());
        }
      }
    }

    match /reports {
      allow list: if isAdmin();
      
      match /{reportId} {
        allow create: if isAuthenticated();
        allow read, update, delete: if isAdmin();
      }
    }

    match /verificationRequests {
      allow list: if isAdmin();
      
      match /{requestId} {
        allow create: if isAuthenticated();
        allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow update, delete: if isAdmin();
      }
    }

    match /users/{userId}/analytics/{analyticId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAuthenticated(); // For incrementing views/impressions
    }
    
    match /ads {
      allow list: if true;
      match /{adId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
  }
}
